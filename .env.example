# Copy to .env and adjust. Every setting here maps 1:1 to a field on the Settings
# class in src/ai_ready_python_codebase/config.py. This file is the discoverable,
# committed contract for configuration — an agent (or a new dev) can read it
# instead of guessing env var names from the code. Keep the two in sync; never
# put real secrets here (.env itself is git-ignored).

# Logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Emit logs as JSON (true) for machines, or human-readable console text (false)
# for local development.
LOG_JSON=true
