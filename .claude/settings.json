{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./.env.example)",
      "Bash(uv sync:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run vulture:*)",
      "Bash(uv run pip-audit:*)",
      "Bash(uv run pre-commit:*)",
      "Bash(test:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Edit(./uv.lock)",
      "Write(./uv.lock)",
      "Edit(./.git/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ruff-fix.sh"
          }
        ]
      }
    ]
  }
}
